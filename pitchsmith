#!/usr/bin/env bash
# ── Pitchsmith · control CLI ──────────────────────────────────────────────────
# One command for the whole app:
#
#   pitchsmith start     build the UI + run the server in the background (:8790)
#   pitchsmith stop      stop the server
#   pitchsmith restart   stop, then start
#   pitchsmith update    pull latest, reinstall deps, rebuild, restart if running
#   pitchsmith status     is it running? where?
#   pitchsmith dev       foreground live-reload (backend :8790 + Vite :5174)
#   pitchsmith logs      tail the server log
#
# Runs one server that serves both the built UI and the API — closest to how a
# packaged build behaves. For live-reload while editing the frontend, use `dev`.
set -euo pipefail

ROOT="$(cd "$(dirname "$0")" && pwd)"
cd "$ROOT"

RUN_DIR="$ROOT/.run"
PID_FILE="$RUN_DIR/server.pid"
LOG_FILE="$RUN_DIR/server.log"
mkdir -p "$RUN_DIR"

# port comes from backend/.env if set, else the Pitchsmith default (8790)
PORT="$(grep -E '^PORT=' backend/.env 2>/dev/null | tail -1 | cut -d= -f2 | tr -d ' ' || true)"
PORT="${PORT:-8790}"
DEV_PORT=5174
URL="http://127.0.0.1:$PORT"

say()  { printf "\033[1;36m▶ %s\033[0m\n" "$1"; }
warn() { printf "\033[1;33m⚠ %s\033[0m\n" "$1"; }
ok()   { printf "\033[1;32m✓ %s\033[0m\n" "$1"; }

# --- helpers -----------------------------------------------------------------

running_pid() {
  # echo the PID of a live server (from the pid file, else whatever holds the
  # port), or nothing. Never errors.
  if [ -f "$PID_FILE" ]; then
    local pid; pid="$(cat "$PID_FILE" 2>/dev/null || true)"
    if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then echo "$pid"; return; fi
  fi
  lsof -ti tcp:"$PORT" -sTCP:LISTEN 2>/dev/null | head -1 || true
}

bootstrap() {
  # first-run: create the venv + install deps if missing
  if [ ! -d backend/.venv ]; then
    say "Creating backend venv + installing deps…"
    python3 -m venv backend/.venv
    ./backend/.venv/bin/pip install -q --upgrade pip
    ./backend/.venv/bin/pip install -q -r backend/requirements.txt
  fi
  if [ ! -d frontend/node_modules ]; then
    say "Installing frontend deps…"
    ( cd frontend && npm install --silent )
  fi
  if [ ! -f backend/.env ]; then
    cp backend/.env.example backend/.env
    warn "Created backend/.env — add ANTHROPIC_API_KEY (the deterministic audit"
    warn "still runs without one, but no pitches are generated)."
  fi
}

wait_for_health() {
  for _ in $(seq 1 30); do
    if curl -sf "$URL/api/v1/health" >/dev/null 2>&1; then return 0; fi
    sleep 0.5
  done
  return 1
}

# --- subcommands -------------------------------------------------------------

cmd_start() {
  local pid; pid="$(running_pid)"
  if [ -n "$pid" ]; then
    ok "Already running (pid $pid) at $URL"
    return 0
  fi
  bootstrap

  say "Building the frontend…"
  ( cd frontend && npm run build >/dev/null )

  say "Starting server on $URL"
  (
    cd backend
    # shellcheck disable=SC1091
    source .venv/bin/activate
    exec python -m app.main
  ) >"$LOG_FILE" 2>&1 &
  echo $! >"$PID_FILE"

  if wait_for_health; then
    ok "Pitchsmith is up → $URL   (logs: pitchsmith logs)"
  else
    warn "Server did not answer in time — check: pitchsmith logs"
    return 1
  fi
}

cmd_stop() {
  local stopped=0
  local pid; pid="$(running_pid)"
  if [ -n "$pid" ]; then
    say "Stopping server (pid ${pid})…"
    kill "$pid" 2>/dev/null || true
    stopped=1
  fi
  # sweep anything left on the API port or the Vite dev port
  for port in "$PORT" "$DEV_PORT"; do
    local pids; pids="$(lsof -ti tcp:"$port" -sTCP:LISTEN 2>/dev/null || true)"
    if [ -n "$pids" ]; then
      say "Stopping process(es) on port ${port}…"
      # shellcheck disable=SC2086
      kill $pids 2>/dev/null || true
      stopped=1
    fi
  done
  rm -f "$PID_FILE"
  sleep 1
  if [ "$stopped" = "1" ]; then ok "Stopped."; else say "Nothing was running."; fi
}

cmd_restart() { cmd_stop; cmd_start; }

cmd_status() {
  local pid; pid="$(running_pid)"
  if [ -n "$pid" ]; then
    ok "Running (pid $pid) at $URL"
    curl -sf "$URL/api/v1/health" 2>/dev/null && echo || true
  else
    say "Not running."
  fi
}

cmd_update() {
  local was_running=0
  [ -n "$(running_pid)" ] && was_running=1

  # pull latest only if this branch tracks a remote (local-only branches skip it)
  if git -C "$ROOT" rev-parse --abbrev-ref --symbolic-full-name '@{u}' >/dev/null 2>&1; then
    say "Pulling latest…"
    git -C "$ROOT" pull --ff-only || warn "git pull skipped (local changes or diverged)."
  else
    say "No upstream for this branch — skipping git pull, just refreshing deps."
  fi

  say "Updating backend deps…"
  ./backend/.venv/bin/pip install -q --upgrade -r backend/requirements.txt 2>/dev/null \
    || { python3 -m venv backend/.venv && ./backend/.venv/bin/pip install -q -r backend/requirements.txt; }

  say "Updating frontend deps…"
  ( cd frontend && npm install --silent )

  say "Rebuilding the frontend…"
  ( cd frontend && npm run build >/dev/null )

  ok "Update complete."
  if [ "$was_running" = "1" ]; then
    say "Restarting (it was running)…"
    cmd_restart
  fi
}

cmd_dev() {
  bootstrap
  exec ./dev.sh
}

cmd_logs() {
  [ -f "$LOG_FILE" ] || { say "No log yet — start the server first."; return 0; }
  tail -n 40 -f "$LOG_FILE"
}

usage() {
  sed -n '2,20p' "$0" | sed 's/^# \{0,1\}//'
}

case "${1:-}" in
  start)    cmd_start ;;
  stop)     cmd_stop ;;
  restart)  cmd_restart ;;
  update)   cmd_update ;;
  status)   cmd_status ;;
  dev)      cmd_dev ;;
  logs)     cmd_logs ;;
  ""|-h|--help|help) usage ;;
  *) warn "Unknown command: $1"; echo; usage; exit 1 ;;
esac
