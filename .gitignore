# --- secrets (never commit) ---
backend/.env
*.env
!backend/.env.example

# --- python ---
backend/.venv/
backend/.python/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/

# --- node / frontend ---
frontend/node_modules/
*.local
# NOTE: frontend/dist/ is intentionally committed (built by the maintainer) so
# end users install and update without needing Node/npm. Rebuild it with
# `npm run build` before committing UI changes.

# --- local data (sqlite db + runtime state) ---
backend/data/

# --- editor / os ---
.DS_Store
.idea/
.vscode/
*.swp

# --- runtime logs / build cache ---
.run/
*.log
*.tsbuildinfo

# --- built macOS app (regenerate with desktop/make-app.sh) ---
Pitchsmith.app/
desktop/AppIcon.iconset/
# NOTE: desktop/AppIcon.icns is committed so the installer can build the local
# launcher .app without Pillow. Regenerate with desktop/make-icon.py.

# --- distributable release build ---
dist-app/
desktop/.cache/
