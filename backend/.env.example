# Pitchsmith backend configuration — copy to .env and fill in.
# Everything AI degrades gracefully with no key: the deterministic anti-AI
# phrase audit still runs, and the classifier falls back to a heuristic.

# --- Anthropic (the pitch pipeline) ---
ANTHROPIC_API_KEY=

# Model tiers (defaults shown — override only if you need to).
# Generation uses the quality tier; classify/audit use the cheap tier.
AI_GENERATE_MODEL=claude-opus-4-8
AI_CLASSIFY_MODEL=claude-haiku-4-5-20251001
AI_AUDIT_MODEL=claude-haiku-4-5-20251001

# How many past human-shipped pitches to feed back as few-shot examples.
FEEDBACK_EXAMPLES=4

# --- server ---
HOST=127.0.0.1
PORT=8790
# SQLite locally; point at Postgres to host: postgresql+psycopg://user:pass@host/db
DATABASE_URL=

# Vite dev server origin (CORS)
FRONTEND_ORIGIN=http://localhost:5174
